# ============================================================
#  IBM watsonx.ai — Travel Planner Agent Configuration
#  Copy this file to .env and fill in your credentials
# ============================================================

# IBM Cloud API Key (required)
# Get yours at: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=Sb_0c-g0eRRxDdA6g6mUAezaSW22ZpP7XT7zOIgIwdOl

# IBM watsonx.ai Project ID (required)
# Found in your watsonx.ai project settings
WATSONX_PROJECT_ID=aec1a72e-8487-498f-b215-173f8433fde0


# IBM watsonx.ai Service URL (region-specific)
# Options:
#   https://us-south.ml.cloud.ibm.com  (Dallas)
#   https://eu-de.ml.cloud.ibm.com     (Frankfurt)
#   https://au-syd.ml.cloud.ibm.com    (Sydney)
WATSONX_URL=https://eu-de.ml.cloud.ibm.com

# Granite Model ID (choose one)
# ibm/granite-3-3-8b-instruct         (fast, recommended)
# ibm/granite-3-8b-instruct           (balanced)
# ibm/granite-13b-chat-v2             (extended context)
WATSONX_MODEL_ID=ibm/granite-4-h-small

# Flask Configuration
FLASK_SECRET_KEY=travel-planner-super-secret-key-change-in-production
FLASK_DEBUG=False
FLASK_PORT=5000

# Application Settings
MAX_TOKENS=2048
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=50
REPETITION_PENALTY=1.1
